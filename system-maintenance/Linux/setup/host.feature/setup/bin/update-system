  _rust_bootstrap_is_rust_available || {
    _package_install_new_only $RUST_PACKAGE
    _rust_bootstrap_is_rust_available || rust_disabled=1
  }
}
_rust_bootstrap_is_rust_available() {
  command -v cargo >/dev/null 2>&1
