	_rust_is_installed $1 && {
		log_detail "$1 is already installed"
		return 0
	}
	local _rust_root_dir=$(printf '%s' $APP_PLATFORM_BIN_PATH | sed -e 's/\/bin//')
	cargo install --root=$_rust_root_dir "$@"
}
rust_update() {
