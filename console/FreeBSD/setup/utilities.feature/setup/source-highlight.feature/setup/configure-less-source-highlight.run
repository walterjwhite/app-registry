#!/bin/sh
: ${conf_console_source_highlight:=/usr/local/bin/src-hilite-lesspipe.sh}
for _CONSOLE in $(find $APP_PLATFORM_PATH/apps/$APPLICATION_NAME/shell -mindepth 1 -maxdepth 1 -type d); do
  printf 'export LESSOPEN="| %s %s"\n' "$conf_console_source_highlight" '%s' > $_CONSOLE/source-highlight-less
  printf 'export LESS=" -R "\n' >> $_CONSOLE/source-highlight-less
done
