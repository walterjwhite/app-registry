#!/bin/sh
_vscodium_install_extensions() {
	if [ -z "$feature_vscodium_extensions" ]; then
		log_warn "feature_vscodium_extensions is empty"
		return 1
	fi
	local vscodium_extension
	for vscodium_extension in $feature_vscodium_extensions; do
		$conf_dev_vscodium_executable --install-extension $vscodium_extension --force
	done
}
_vscodium_install_extensions
