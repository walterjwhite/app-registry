readonly GNU_SED=gsed
readonly _SUDO_CMD="sudo"
readonly IO_STAT_ARGS='-f %OLp'
readonly REQUIRED_ARGUMENTS="_JAIL_PATH:The path to the jail configuration directory"
_include_optional . beep context git install logging net os-installer paths platform wait
_metadata_load
: ${beep_enabled:=0}
: ${conf_log_beep_timeout:=5}
