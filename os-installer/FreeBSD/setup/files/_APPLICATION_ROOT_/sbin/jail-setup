: ${conf_log_long_running_cmd:=30}
: ${conf_log_long_running_cmd_lines:=1000}
: ${conf_log_date_time_to_console:=0}
command -v mail >/dev/null 2>&1 || conf_log_mail_disabled=1
[ -z "${GITHUB_ACTIONS}" ] && [ -z "${CI}" ] && {
  [ -t 0 ] && [ -t 1 ] && interactive=1
}
: ${conf_network_test_timeout:=5}
: ${conf_network_test_targets:="http://connectivity-check.ubuntu.com http://example.org http://www.google.com http://telehack.com http://lxer.com"}
: ${curl_flags:="--connect-timeout 5 --max-time 30"}
: ${conf_wait_interval:=30}
os_installer_instance=$(date +%s)
log_logfile=/var/log/walterjwhite/os-installer-$os_installer_instance.log
: ${conf_os_installer_ssh_key_type:=ed25519}
