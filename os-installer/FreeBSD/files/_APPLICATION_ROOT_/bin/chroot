_GO_BOOTSTRAP() {
	_GO_BOOTSTRAP_IS_GO_AVAILABLE || {
		_PACKAGE_INSTALL $_GO_PACKAGE
		_GO_BOOTSTRAP_IS_GO_AVAILABLE || _GO_DISABLED=1
	}
}
_GO_BOOTSTRAP_IS_GO_AVAILABLE() {
	which go >/dev/null 2>&1
}
_GO_INSTALL() {
	_GO_BOOTSTRAP
	_go_walterjwhite_conf
	GO111MODULE=on GOPATH=$_GO_INSTALL_PATH go install $_GO_OPTIONS -a -race -ldflags $_BUILD_OPTIONS "$@" || {
		_WARN "go install failed: $_GO_OPTIONS $@"
		_WARN "  http_proxy: $http_proxy"
		_WARN "  git  proxy: $(git config --global http.proxy)"
	}
}
_go_walterjwhite_conf() {
	_BUILD_DATE=$(date +"%Y/%m/%d-%H:%M:%S")
	_VERSION=$(gcb)
	_SCM_ID=$(git-head)
	_GO_VERSION=$(go version | awk {'print$3'})
	_OS_ARCHITECTURE=$(go version | awk {'print$4'})
	_APP_NAME_FLAG="${_CONF_DEV_APPLICATION_PACKAGE_PREFIX}.ApplicationName=$_APP_NAME"
	_APP_VERSION_FLAG="${_CONF_DEV_APPLICATION_PACKAGE_PREFIX}.ApplicationVersion=$_VERSION"
	_SCM_VERSION_ID_FLAG="${_CONF_DEV_APPLICATION_PACKAGE_PREFIX}.SCMId=$_SCM_ID"
	_BUILD_DATE_FLAG="${_CONF_DEV_APPLICATION_PACKAGE_PREFIX}.BuildDate=$_BUILD_DATE"
	_GO_VERSION_FLAG="${_CONF_DEV_APPLICATION_PACKAGE_PREFIX}.GoVersion=$_GO_VERSION"
	_OS_ARCHITECTURE_FLAG="${_CONF_DEV_APPLICATION_PACKAGE_PREFIX}.OSArchitecture=$_OS_ARCHITECTURE"
	_BUILD_OPTIONS="-X $_APP_NAME_FLAG -X $_APP_VERSION_FLAG -X $_SCM_VERSION_ID_FLAG -X $_BUILD_DATE_FLAG -X $_GO_VERSION_FLAG -X $_OS_ARCHITECTURE_FLAG"
	_DEBUG "#####"
	_DEBUG "$_APP_NAME"
	_DEBUG "$_VERSION"
	_DEBUG "$_SCM_ID"
	_DEBUG "$_BUILD_DATE"
	_DEBUG "$_GO_VERSION"
	_DEBUG "$_OS_ARCHITECTURE"
}
_GO_UPDATE() {
	:
}
_GO_UNINSTALL() {
	go uninstall "$@"
}
_GO_IS_INSTALLED() {
	_setup_type_is_installed "$1"
}
_GO_IS_FILE() {
	return 1
}
_NPM_BOOTSTRAP() {
	_NPM_BOOTSTRAP_IS_NPM_AVAILABLE || {
		_PACKAGE_INSTALL $_NPM_PACKAGE
		_NPM_BOOTSTRAP_IS_NPM_AVAILABLE || _NPM_DISABLED=1
	}
	_NPM_SETUP_PROXY
}
_NPM_BOOTSTRAP_IS_NPM_AVAILABLE() {
	which npm >/dev/null 2>&1
}
_NPM_INSTALL() {
	_NPM_BOOTSTRAP
	local npm_package
	for npm_package in "$@"; do
		_NPM_IS_INSTALLED $npm_package || npm install -s -g "$npm_package"
	done
}
_NPM_UNINSTALL() {
	_NPM_BOOTSTRAP
	npm uninstall -s -g "$@"
}
_NPM_IS_INSTALLED() {
	_NPM_BOOTSTRAP
	npm list -g $1 >/dev/null
}
_NPM_IS_FILE() {
	return 1
}
_NPM_SETUP_PROXY() {
	if [ -n "$http_proxy" ]; then
		_WARN "Configuring NPM to use an HTTP proxy: $http_proxy"
		npm config set proxy $http_proxy
		npm config set https-proxy $https_proxy
		_defer _NPM_CLEAR_PROXY
	fi
}
_NPM_CLEAR_PROXY() {
	_WARN "Reverting NPM HTTP proxy: $http_proxy"
	npm config rm proxy
	npm config rm https-proxy
}
_PACKAGE_INSTALL_NEW_ONLY() {
	local packages
	local package
	for package in "$@"; do
		_PACKAGE_IS_INSTALLED $package || {
			if [ -n "$packages" ]; then
				packages="$packages $package"
			else
				packages="$package"
			fi
		}
	done
	if [ -n "$packages" ]; then
		_PACKAGE_INSTALL_DO $packages
	else
		_WARN "Packages [$*] are already installed, skipping"
		return 0
	fi
}
_PACKAGE_IS_FILE() {
	return 1
}
_PACKAGE_ENABLED() {
	return 0
}
