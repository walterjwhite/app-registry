  else
    pip install -U --no-input --user "$1" >/dev/null
  fi
}
_pypi_uninstall_do() {
  if [ "${INSTALL_TARGET:-USER}" = "SYSTEM" ]; then
    sudo_run pip uninstall -y "$1" >/dev/null
  else
    pip uninstall -y "$1" >/dev/null
  fi
}
