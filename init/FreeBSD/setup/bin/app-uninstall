  pkg_update${freebsd_pkg_suffix} "$@"
}
_package_install_do() {
  pkg_install${freebsd_pkg_suffix} "$@"
}
_package_uninstall_do() {
  pkg_uninstall${freebsd_pkg_suffix} "$@"
}
_package_is_installed() {
  pkg_is_installed${freebsd_pkg_suffix} "$@"
}
package_bootstrap() {
  pkg_bootstrap${freebsd_pkg_suffix} "$@"
}
pkg_bootstrap_is_package_available() {
  return 0
}
_ssh_prepare_ssh_conf() {
  local _path=$1
  local _user=$2
  sudo_run mkdir -p "$_path/.ssh/socket"
  sudo_run chmod 700 "$_path/.ssh/socket"
  printf 'StrictHostKeyChecking no\n' >>"$_path/.ssh/config"
  _ssh_init_bastion_host "$_path"
  [ "$_user" = "root" ] && return
  if [ -e /root/.ssh ]; then
    log_info "copying host ssh -> $_path/.ssh"
    sudo_run cp /root/.ssh/id* /root/.ssh/config /root/.ssh/known_hosts "$_path/.ssh"
  fi
  if [ -e /root/.config/walterjwhite/shell ]; then
    log_info "copying walterjwhite conf -> $_path/.config/walterjwhite/shell"
    sudo_run rm -rf "$_path/.config/walterjwhite/shell" && sudo_run mkdir -p "$_path/.config/walterjwhite"
    sudo_run cp -r /root/.config/walterjwhite/shell "$_path/.config/walterjwhite/shell"
  else
    log_warn "no walterjwhite conf found"
    find /tmp -maxdepth 1
  fi
  sudo_run chown -R "$_user:$_user" "$_path"
}
_ssh_init_bastion_host() {
  local _path=$1
  [ -z "$bastion_host" ] && return 1
  log_info "setting up SSH Bastion host: $_path"
  _ssh_bastion_host "$_path"
  _ssh_bastion_proxies "$_path"
  chmod 600 "$_path/.ssh/config"
}
_ssh_bastion_host() {
  local _path=$1
  log_info "setting up SSH Bastion host: $_path"
  printf 'Host host-proxy\n' >>"$_path/.ssh/config"
  printf ' Hostname %s\n' "$bastion_host" >>"$_path/.ssh/config"
  printf ' User root\n' >>"$_path/.ssh/config"
}
_ssh_bastion_proxies() {
  local _path=$1
  for bastion_hostname in $(printf '%s' "$bastion_hostnames" | sort -u); do
    _ssh_bastion_proxy "$_path"
  done
}
_ssh_bastion_proxy() {
  local _path=$1
  log_info "setting up SSH host proxy: $_path"
  printf 'Host %s\n' "$bastion_hostname" >>"$_path/.ssh/config"
  printf ' ProxyJump host-proxy:%s\n' "$bastion_port" >>"$_path/.ssh/config"
  printf ' User root\n' >>"$_path/.ssh/config"
}
readonly APPLICATION_NAME=init
readonly APPLICATION_START_TIME=$(date +%s)
readonly APPLICATION_CMD=$(basename $0)
readonly APP_PLATFORM_ARCHITECTURE=$(uname -m)
readonly APP_PLATFORM_OS_NAME=$(uname)
case "$APP_PLATFORM_OS_NAME" in
Darwin)
  readonly APP_PLATFORM_PLATFORM="Apple"
  ;;
MINGW64_NT-* | MSYS_NT-*)
  readonly APP_PLATFORM_PLATFORM="Windows"
  ;;
*)
  readonly APP_PLATFORM_PLATFORM="$APP_PLATFORM_OS_NAME"
  ;;
esac
: ${APP_PLATFORM_ROOT:=/}
[ "$HOME" = "/" ] || [ -z "$HOME" ] && HOME=/root
readonly RUN_PATH=/tmp/$USER/walterjwhite/app
readonly APP_CONTEXT="default"
readonly APPLICATION_CONTEXT_GROUP=$RUN_PATH/$APP_CONTEXT
readonly APPLICATION_CMD_DIR=$APPLICATION_CONTEXT_GROUP/$APPLICATION_NAME/$APPLICATION_CMD
readonly APPLICATION_PIPE=$APPLICATION_CMD_DIR/$$
readonly APPLICATION_PIPE_DIR=$(dirname $APPLICATION_PIPE)
readonly TAR_ARGS=" -f - "
readonly GNU_GREP=/usr/local/bin/ggrep
readonly GNU_SED=gsed
readonly GNU_REALPATH=grealpath
readonly SUDO_CMD="sudo"
APP_PLATFORM_ROOT=$($GNU_REALPATH -m $APP_PLATFORM_ROOT)
case $0 in
*${HOME}*)
  APP_PLATFORM_PATH=$(printf '%s' "$APP_PLATFORM_ROOT/$HOME/.local/walterjwhite" | tr -s /)
  readonly APP_PLATFORM_CONFIG_PATH=$(printf '%s' $APP_PLATFORM_ROOT${HOME}/.config/walterjwhite/shell | tr -s /)
  readonly APP_PLATFORM_BIN_PATH=$(printf '%s' $APP_PLATFORM_ROOT${HOME}/.local/bin | tr -s /)
  ;;
*)
  APP_PLATFORM_PATH=$(printf '%s' "$APP_PLATFORM_ROOT/usr/local/walterjwhite" | tr -s /)
  readonly APP_PLATFORM_CONFIG_PATH=$(printf '%s' $APP_PLATFORM_ROOT/usr/local/etc/walterjwhite/shell | tr -s /)
  readonly APP_PLATFORM_BIN_PATH=$(printf '%s' $APP_PLATFORM_ROOT/usr/local/bin | tr -s /)
  ;;
esac
readonly APP_PLATFORM_DATA_PATH=$(printf '%s' ${APP_PLATFORM_ROOT}$HOME/.data | tr -s /)
readonly APP_PLATFORM_APPS_PATH=$APP_PLATFORM_PATH/apps
readonly APP_PLATFORM_EXTENSIONS_PATH=$APP_PLATFORM_PATH/extensions
readonly APP_DATA_PATH=$APP_PLATFORM_DATA_PATH/$APPLICATION_NAME
readonly APP_PATH=$APP_PLATFORM_APPS_PATH/$APPLICATION_NAME
readonly APP_CONFIG_PATH=$APP_PLATFORM_CONFIG_PATH/$APPLICATION_NAME
readonly APPLICATION_METADATA_PATH=$APP_PATH/.metadata
readonly PLATFORM_PACKAGES="coreutils git gsed gnugrep gtar gawk shfmt shuf sudo"
readonly NPM_PACKAGE="npm"
readonly RUST_PACKAGE="rust"
readonly PYPI_PACKAGE="python39 py39-pip"
readonly GO_PACKAGE="go"
readonly REQUIRED_ARGUMENTS="_APPLICATIONS:Applications to remove"
_metadata_load
_include_optional beep context init logging net paths platform wait
: ${conf_beep_enabled:=0}
: ${conf_log_beep_timeout:=5}
: ${conf_log_beep_err:='L32c'}
: ${conf_log_beep_alrt:='L32f'}
: ${conf_log_beep_scs:='L32a'}
: ${conf_log_beep_wrn:=''}
: ${conf_log_beep_info:=''}
: ${conf_log_beep_detail:=''}
: ${conf_log_beep_debug:=''}
: ${conf_log_beep_stdin:='L32ab'}
: ${conf_log_sudo_beep_tone:=L32aL8fL32c}
: ${APP_CONTEXT:=$_CONSOLE_CONTEXT_ID}
