#!/bin/sh
_extract_extract() {
  if [ $# -lt 2 ]; then
    log_warn "expecting 2 arguments, source file, and target to extract to"
    return 1
  fi
  log_info "extracting $1"
  [ -n "$clean" ] && {
    rm -rf $2
    mkdir -p $2
  }
  case $1 in
  *.tar.gz | *.tgz | *.tar.bz2 | *.tbz2 | *.tar.xz)
    tar xf $1 -C $2
    ;;
  *.zip)
    unzip -q $1 -d $2
    ;;
  *)
    log_warn "extension unsupported - $1"
    return 2
    ;;
  esac
}
_download_fetch() {
  mkdir -p "$TARGET_APP_PLATFORM_CACHE_PATH"
  local _cached_filename
  if [ $# -gt 1 ]; then
    _cached_filename="$2"
  else
    _cached_filename=$(basename "$1" | sed -e 's/?.*$//')
  fi
  download_file="$TARGET_APP_PLATFORM_CACHE_PATH/$_cached_filename"
  [ -z "$no_cache" ] && {
    [ -s "$download_file" ] && {
      log_detail "$1 already downloaded to: $download_file"
      return
    }
  }
  if [ -z "$download_disabled" ]; then
    log_info "downloading $1 -> $download_file"
    curl $conf_curl_flags -f -o "$download_file" -sL "$1"
    local _curl_status=$?
    if [ "$_curl_status" -ne 0 ]; then
      rm -f "$download_file"
      log_warn "failed to download ($_curl_status): $1"
      return $_curl_status
    fi
  else
    _stdin_continue_if "Please manually download: $1 and place it in $download_file" "Y/n"
  fi
}
_download_install_file() {
  warn_on_error=1 validation_require "$1" "1 (_download_install_file) target filename" || return 1
  warn_on_error=1 validation_require "$download_file" "download_file" || return 1
  : ${_install_file_chmod:=444}
  log_info "installing $download_file -> $1"
  if [ "${INSTALL_TARGET:-USER}" = "SYSTEM" ]; then
    sudo_run mkdir -p $(dirname $1)
    sudo_run cp "$download_file" $1
    sudo_run chmod $_install_file_chmod $1
  else
    mkdir -p $(dirname $1)
    cp "$download_file" $1
    chmod $_install_file_chmod $1
  fi
  unset download_file
  [ -e $1 ] || {
    log_warn "failed to install file to: $1"
    return 1
  }
  _install_record_path "$1"
}
_download_verify() {
  shasum -a 512 -c $1 >/dev/null 2>&1
}
case $APP_PLATFORM_PLATFORM in
Apple) cursor_platform=darwin ;;
Linux) cursor_platform=linux ;;
*) log_warn "unsupported platform: $APP_PLATFORM_PLATFORM" ;;
esac
case $APP_PLATFORM_ARCHITECTURE in
x86_64) cursor_architecture=x64 ;;
arm_64) cursor_architecture=arm64 ;;
*) log_warn "unsupported architecture" ;;
esac
_cursor_get_latest_version() {
  curl $conf_curl_flags -fsS "https://api2.cursor.sh/updates/latest-build?platform=${cursor_platform}&architecture=${cursor_architecture}" 2>/dev/null |
    grep -o '"version":"[^"]*"' | head -1 | cut -f2 -d: | tr -d '"'
}
CURSOR_VERSION=$(_cursor_get_latest_version)
: ${CURSOR_VERSION:="2026.03.25-933d5a6"}
readonly CURSOR_VERSION
readonly CURSOR_DOWNLOAD_URL="https://downloads.cursor.com/lab/${CURSOR_VERSION}/${cursor_platform}/${cursor_architecture}/agent-cli-package.tar.gz"
readonly CURSOR_INSTALL_PATH=/opt/cursor
_cursor_is_installed() {
  command -v cursor-agent >/dev/null 2>&1
}
_cursor_get_installed_version() {
  cursor --version 2>&1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1
}
_cursor_install() {
  [ -z "$cursor_platform" ] && return 1
  [ -z "$cursor_architecture" ] && return 1
  _download_fetch "$CURSOR_DOWNLOAD_URL" "$CURSOR_VERSION-$(basename $CURSOR_DOWNLOAD_URL)"
  clean=1 _extract_extract $download_file $CURSOR_INSTALL_PATH
  mv $CURSOR_INSTALL_PATH/dist-package/* $CURSOR_INSTALL_PATH/
  rm -rf $CURSOR_INSTALL_PATH/dist-package
  _install_record_dir "$CURSOR_INSTALL_PATH"
  for _bin in cursor-agent cursor-askpass cursor-sandbox; do
    ln -sf "$CURSOR_INSTALL_PATH/$_bin" "$TARGET_APP_PLATFORM_BIN_PATH/$_bin"
    _install_record_symlink "$TARGET_APP_PLATFORM_BIN_PATH/$_bin"
  done
}
_cursor_is_installed || _cursor_install
