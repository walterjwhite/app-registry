#!/bin/sh
_extract_extract() {
  if [ $# -lt 2 ]; then
    log_warn "expecting 2 arguments, source file, and target to extract to"
    return 1
  fi
  log_info "extracting $1"
  [ -n "$clean" ] && {
    rm -rf $2
    mkdir -p $2
  }
  case $1 in
  *.tar.gz | *.tgz | *.tar.bz2 | *.tbz2 | *.tar.xz)
    tar xf $1 -C $2
    ;;
  *.zip)
    unzip -q $1 -d $2
    ;;
  *)
    log_warn "extension unsupported - $1"
    return 2
    ;;
  esac
}
_download_fetch() {
  mkdir -p "$TARGET_APP_PLATFORM_CACHE_PATH"
  local _cached_filename
  if [ $# -gt 1 ]; then
    _cached_filename="$2"
  else
    _cached_filename=$(basename "$1" | sed -e 's/?.*$//')
  fi
  download_file="$TARGET_APP_PLATFORM_CACHE_PATH/$_cached_filename"
  [ -z "$no_cache" ] && {
    [ -s "$download_file" ] && {
      log_detail "$1 already downloaded to: $download_file"
      return
    }
  }
  if [ -z "$download_disabled" ]; then
    log_info "downloading $1 -> $download_file"
    curl $conf_curl_flags -f -o "$download_file" -sL "$1"
    local _curl_status=$?
    if [ "$_curl_status" -ne 0 ]; then
      rm -f "$download_file"
      log_warn "failed to download ($_curl_status): $1"
      return $_curl_status
    fi
  else
    _stdin_continue_if "Please manually download: $1 and place it in $download_file" "Y/n"
  fi
}
_download_install_file() {
  warn_on_error=1 validation_require "$1" "1 (_download_install_file) target filename" || return 1
  warn_on_error=1 validation_require "$download_file" "download_file" || return 1
  : ${_install_file_chmod:=444}
  log_info "installing $download_file -> $1"
  if [ "${INSTALL_TARGET:-USER}" = "SYSTEM" ]; then
    sudo_run mkdir -p $(dirname $1)
    sudo_run cp "$download_file" $1
    sudo_run chmod $_install_file_chmod $1
  else
    mkdir -p $(dirname $1)
    cp "$download_file" $1
    chmod $_install_file_chmod $1
  fi
  unset download_file
  [ -e $1 ] || {
    log_warn "failed to install file to: $1"
    return 1
  }
  _install_record_path "$1"
}
_download_verify() {
  shasum -a 512 -c $1 >/dev/null 2>&1
}
readonly DEVIN_BASE_URL="https://static.devin.ai/cli"
_get_latest_devin_version_info() {
    _get_devin_manifest
    _get_devin_target_triple || return 1
    latest_devin_version=$(jq -r '.version' $devin_manifest)
    latest_devin_download_url=$(jq -r --arg target "$devin_target_triple" '.platforms[$target].url' $devin_manifest)
    latest_devin_checksum=$(jq -r --arg target "$devin_target_triple" '.platforms[$target].sha256' $devin_manifest)
}
_get_devin_manifest() {
    no_cache=1 _download_fetch "${DEVIN_BASE_URL}/current/manifest.json" "devin-manifest.json"
    devin_manifest=$download_file
}
_get_devin_target_triple() {
    case "$APP_PLATFORM_OS_NAME" in
    Darwin)
        case "$APP_PLATFORM_ARCHITECTURE" in
        arm64) devin_target_triple="aarch64-apple-darwin" ;;
        x86_64) devin_target_triple="x86_64-apple-darwin" ;;
        esac
        ;;
    Linux)
        case "$APP_PLATFORM_ARCHITECTURE" in
        x86_64) devin_target_triple="x86_64-unknown-linux" ;;
        aarch64) devin_target_triple="aarch64-unknown-linux" ;;
        esac
        ;;
    esac
    if [ -z "$devin_target_triple" ]; then
        log_warn "devin has no released build for $APP_PLATFORM_OS_NAME $APP_PLATFORM_ARCHITECTURE"
        return 1
    fi
}
_get_installed_devin_version() {
    if [ -e $TARGET_APP_PLATFORM_BIN_PATH/devin ]; then
        $TARGET_APP_PLATFORM_BIN_PATH/devin --version | awk '{print $NF}'
    fi
}
_devin_install() {
    devin_url=$latest_devin_download_url
    versioned_filename="devin-$latest_devin_version-$devin_target_triple.tar.gz"
    _download_fetch $devin_url "$versioned_filename"
    log_detail "verifying checksum: $latest_devin_checksum"
    printf '%s  %s' "$latest_devin_checksum" "$download_file" | sha256sum -c - || {
        log_warn "checksum verification failed for $versioned_filename"
        return 1
    }
    log_detail "checksum verification passed"
    cd /tmp
    versioned_extract_dir="devin-$latest_devin_version"
    mkdir -p "/tmp/$versioned_extract_dir"
    _extract_extract $download_file "/tmp/$versioned_extract_dir"
    exit_defer rm -rf "/tmp/$versioned_extract_dir"
    local _dest="$TARGET_APP_PLATFORM_BIN_PATH/devin"
    mv "/tmp/$versioned_extract_dir/bin/devin" "$_dest"
    chmod 755 "$_dest"
    _install_record_path "$_dest"
}
_devin_is_latest_version() {
    local installed_devin_version=$(_get_installed_devin_version)
    [ "$installed_devin_version" = "$latest_devin_version" ]
}
if _get_latest_devin_version_info; then
    if ! _devin_is_latest_version; then
        log_info "installing devin $latest_devin_version"
        _devin_install
    else
        log_info "devin is already installed and up-to-date"
    fi
else
    log_warn "unable to determine devin release info for this platform"
    false
fi
