readonly APP_DATA_PATH=$APP_PLATFORM_DATA_PATH/$APPLICATION_NAME
readonly APP_LIBRARY_PATH=$APP_PLATFORM_LIBRARY_PATH/$APPLICATION_NAME
[ "$HOME" = "/" ] || [ -z "$HOME" ] && HOME=/root
readonly REQUIRED_ARGUMENTS="secrets_action:delete get put generate find value-grep"
_include_optional . beep context logging net paths platform qr secrets wait
_metadata_load
: ${RSRC_BEEP:=/tmp/beep}
: ${conf_log_beep_timeout:=5}
