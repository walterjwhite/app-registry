	readonly NPM_PACKAGE="net-libs/nodejs"
	readonly RUST_PACKAGE="dev-lang/rust"
	readonly PYPI_PACKAGE="dev-lang/python"
	readonly GO_PACKAGE="dev-lang/go"
	readonly EXPECT_PACKAGE="dev-tcltk/expect"
	;;
