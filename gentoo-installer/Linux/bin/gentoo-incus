		printf 'sys-firmware/intel-microcode intel-ucode\n' >>/etc/portage/package.license/firmware
		_package_install sys-firmware/intel-microcode
		;;
	AMD)
		;;
	*)
		_warn "Unknown CPU: $GENTOO_CPU_VENDOR"
		;;
	esac
}
